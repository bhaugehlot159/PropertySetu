PRO_PORT=5200
NODE_ENV=production
MONGO_URI=mongodb://127.0.0.1:27017/propertysetu_pro

# Storage provider: cloudinary | s3
STORAGE_PROVIDER=cloudinary

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=propertysetu/properties

# AWS S3 hints (used when STORAGE_PROVIDER=s3)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=replace_with_secure_secret

# CORS
CORS_ORIGIN=https://propertysetu.in,https://www.propertysetu.in

# Core auth
JWT_SECRET=replace_with_strong_jwt_secret
ADMIN_REGISTRATION_KEY=replace_with_admin_registration_key
CORE_EXPOSE_OTP=false
