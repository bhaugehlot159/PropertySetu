PRO_PORT=5200
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/propertysetu_pro

# Choose one: cloudinary or s3
STORAGE_PROVIDER=cloudinary

# Cloudinary (required when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=propertysetu/properties

# AWS S3 hints (used when STORAGE_PROVIDER=s3)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx

# Comma-separated origins for CORS
CORS_ORIGIN=http://localhost:5174

# Core v3 auth
JWT_SECRET=replace_with_secure_jwt_secret
ADMIN_REGISTRATION_KEY=replace_with_admin_registration_key
CORE_EXPOSE_OTP=false
EXPOSE_OTP_HINT=false

# OTP Delivery (real mode)
# Options: webhook | twilio-sms | console
OTP_DELIVERY_PROVIDER=webhook
OTP_DELIVERY_REQUIRE_REAL=true
OTP_DELIVERY_TIMEOUT_MS=8000
OTP_ALLOW_STATIC_IN_PRODUCTION=false
OTP_WEBHOOK_URL=https://your-otp-gateway.example.com/send
OTP_WEBHOOK_AUTH_TOKEN=replace_with_secure_token
OTP_WEBHOOK_SECRET=replace_with_hmac_secret
OTP_DEFAULT_COUNTRY_CODE=+91
OTP_SMS_TEMPLATE=PropertySetu OTP: {OTP}. Valid for {TTL_MIN} minutes.

# Twilio SMS (required only when OTP_DELIVERY_PROVIDER=twilio-sms)
TWILIO_ACCOUNT_SID=replace_with_account_sid
TWILIO_AUTH_TOKEN=replace_with_auth_token
TWILIO_MESSAGING_SERVICE_SID=replace_with_messaging_service_sid
TWILIO_FROM_NUMBER=

# Keep demo fallback disabled for production-like behavior
CORE_ENABLE_PAYMENT_DEV_FALLBACK=false
