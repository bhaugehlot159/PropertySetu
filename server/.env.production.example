PORT=5000
NODE_ENV=production
JWT_SECRET=replace-with-long-random-secret
MONGODB_URI=replace-with-your-mongodb-uri-if-used
RAZORPAY_KEY_ID=replace-if-enabled
RAZORPAY_KEY_SECRET=replace-if-enabled
ADMIN_REGISTRATION_KEY=replace-with-admin-registration-secret
CORE_EXPOSE_OTP=false
EXPOSE_OTP_HINT=false
OTP_DELIVERY_PROVIDER=webhook
OTP_DELIVERY_REQUIRE_REAL=true
OTP_WEBHOOK_URL=https://your-otp-gateway.example.com/send
OTP_WEBHOOK_AUTH_TOKEN=replace-with-webhook-token
OTP_WEBHOOK_SECRET=replace-with-webhook-hmac-secret
OTP_ALLOW_STATIC_IN_PRODUCTION=false
CORE_ENABLE_PAYMENT_DEV_FALLBACK=false
